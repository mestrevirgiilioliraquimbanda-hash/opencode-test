generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerRank {
  INICIANTE
  AVANCADO
  BIG_PLAYER
  INSTITUCIONAL
}

enum CoreType {
  AUREX_13
  AUREX_X
  DIAMOND
  GOLD
  008
}

model Operator {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  rank              PlayerRank         @default(INICIANTE)
  tokenBalance      Int                @default(1000)
  reputationScore   Float              @default(0.0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  transactions      SocialTransaction[]
  clanId            String?
  clan              Clan?              @relation(fields: [clanId], references: [id])
  ownedClans        Clan[]

  @@map("operators")
}

model OperationalCore {
  id              String             @id @default(uuid())
  name            String             @unique
  type            CoreType
  energyCapacity  Int
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  transactions    SocialTransaction[]

  @@map("operational_cores")
}

model Clan {
  id              String             @id @default(uuid())
  name            String             @unique
  description     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  operators       Operator[]
  ownerId         String
  owner           Operator           @relation(fields: [ownerId], references: [id])

  @@map("clans")
}

model SocialTransaction {
  id                String             @id @default(uuid())
  operatorId        String
  operationalCoreId String
  energyConsumed    Int
  reputationDelta   Float             @default(0)
  tokenDelta        Int               @default(0)
  type              String
  description       String?
  createdAt         DateTime          @default(now())
  operator          Operator           @relation(fields: [operatorId], references: [id])
  operationalCore   OperationalCore    @relation(fields: [operationalCoreId], references: [id])

  @@map("social_transactions")
}
