generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlayerRank {
  INICIANTE
  AVANCADO
  BIG_PLAYER
  INSTITUCIONAL
}

enum CoreType {
  AUREX_13
  AUREX_X
  DIAMOND
  GOLD
  CORE_008
}

model Operator {
  id              String              @id @default(uuid())
  email           String              @unique
  name            String?
  rank            PlayerRank          @default(INICIANTE)
  tokenBalance    Int                 @default(1000)
  reputationScore Float               @default(0.0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  clanId          String?
  clan            Clan?               @relation("ClanMembers", fields: [clanId], references: [id])
  
  ownedClans      Clan[]              @relation("ClanOwner")
  transactions    SocialTransaction[]
  arenaTransactions ArenaTransaction[]

  @@map("operators")
}

model Clan {
  id              String              @id @default(uuid())
  name            String              @unique
  description     String?
  reputationScore Float               @default(0.0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  members         Operator[]          @relation("ClanMembers")
  ownerId         String
  owner           Operator            @relation("ClanOwner", fields: [ownerId], references: [id])

  @@map("clans")
}

model OperationalCore {
  id              String              @id @default(uuid())
  name            String              @unique
  coreType        CoreType
  energyCapacity  Int
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  transactions    SocialTransaction[]

  @@map("operational_cores")
}

model SocialTransaction {
  id                String            @id @default(uuid())
  operatorId        String
  operationalCoreId String
  energyConsumed    Int
  reputationDelta   Float             @default(0)
  tokenDelta        Int               @default(0)
  type              String
  description       String?
  createdAt         DateTime          @default(now())
  
  operator          Operator          @relation(fields: [operatorId], references: [id])
  operationalCore   OperationalCore   @relation(fields: [operationalCoreId], references: [id])

  @@map("social_transactions")
}

model ArenaTransaction {
  id                String            @id @default(uuid())
  playerId          String
  arenaId           String
  transactionAmount Int
  arenaPrice        Float
  createdAt         DateTime          @default(now())
  
  player            Operator          @relation(fields: [playerId], references: [id])

  @@map("arena_transactions")
}